# Copy this to .env and fill in your values

# Database — PostgreSQL via asyncpg (matches production)
DATABASE_URL=postgresql+asyncpg://stadiummind:stadiummind_dev@localhost:5432/stadiummind

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PREDICTION_MODEL=gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Firebase (optional — leave blank to use demo/mock auth)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=

USE_MOCK_GEMINI=true
GEMINI_BUDGET_LIMIT=15

# Security
SECRET_KEY=change_this_to_a_random_secret_key_at_least_32_chars

# CORS — add your Vercel URL when deploying
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000

# Simulation tick interval (seconds)
SIMULATION_INTERVAL_SECONDS=60
