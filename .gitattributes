# Normalize line endings
* text=auto eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
*.woff binary
*.ttf binary
*.faiss binary
